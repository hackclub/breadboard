# Breadboard app environment
# Copy to .env.local for local development. Never commit real secrets.

# App URL used by auth callbacks and server-side redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL connection string used by the app and Drizzle.
DATABASE_URL=postgresql://user:password@localhost:5432/breadboard
# Set to false for local Postgres without SSL.
DATABASE_SSL=false

# Better Auth secret. Generate with: bunx --bun better-auth secret
BETTER_AUTH_SECRET=

# Hack Club OAuth provider credentials.
HACKCLUB_CLIENT_ID=
HACKCLUB_CLIENT_SECRET=

# Editor backend. The Next app rewrites editor API routes to this FastAPI service.
EDITOR_BACKEND_URL=http://127.0.0.1:8001
NEXT_PUBLIC_EDITOR_BACKEND_URL=/api

# Optional: required only when building the full ESP32 emulation Docker image
# without local prebuilt QEMU libs in editor-backend/prebuilt/qemu.
VELXIO_LICENSE_KEY=
QEMU_RELEASE_URL=

# S3-compatible storage for project screenshots.
# Silo uses path-style public URLs: https://silo.deployor.dev/testing-breadboard/file.png
S3_ENDPOINT=https://silo.deployor.dev
S3_REGION=auto
S3_BUCKET=testing-breadboard
S3_PUBLIC_URL=https://silo.deployor.dev/testing-breadboard
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

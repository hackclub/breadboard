# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.archive/
temp/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local ESP32 QEMU runtime binaries extracted for editor backend dev
/editor-backend/prebuilt/qemu/*.so
/editor-backend/prebuilt/qemu/*.bin

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

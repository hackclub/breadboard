{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!node_modules",
      "!.next",
      "!dist",
      "!build",
      "!temp",
      "!.archive",
      "!.kilo",
      "!oldvelxio",
      "!editor-backend",
      "!public/boards",
      "!public/components",
      "!public/component-svgs",
      "!public/firmware",
      "!public/wasm",
      "!public/components-metadata.json",
      "!public/littlefs.wasm",
      "!src/app/editor/velxio-styles",
      "!src/components/velxio",
      "!src/lib/velxio",
      "!src/services/velxio"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noAutofocus": "off"
      },
      "correctness": {
        "noUnusedImports": "off"
      },
      "performance": {
        "noImgElement": "off"
      },
      "suspicious": {
        "noUnknownAtRules": "off"
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "off"
      }
    }
  }
}

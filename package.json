{
  "name": "breadboard",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.6",
  "scripts": {
    "dev": "bunx --bun next dev",
    "build": "bunx --bun next build",
    "start": "bunx --bun next start",
    "lint": "bunx --bun biome check",
    "format": "bunx --bun biome format --write",
    "editor:backend": "FRONTEND_URL=http://localhost:3000 .venv-editor-backend/bin/uvicorn --app-dir editor-backend app.main:app --host 127.0.0.1 --port 8001",
    "editor:qemu:extract": "bash editor-backend/scripts/extract-qemu-runtime-from-ghcr.sh",
    "editor:qemu:check": "bash editor-backend/scripts/check-qemu-runtime.sh",
    "editor:backend:docker": "docker compose -f docker-compose.editor.yml up editor-backend --build",
    "editor:backend:docker:build": "docker compose -f docker-compose.editor.yml build editor-backend",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate": "bunx --bun drizzle-kit migrate",
    "db:push": "bunx --bun drizzle-kit push",
    "db:studio": "bunx --bun drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@better-auth/drizzle-adapter": "^1.6.16",
    "@google/model-viewer": "^4.3.1",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^2.0.1",
    "@wokwi/elements": "1.9.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "avr8js": "0.21.0",
    "axios": "^1.17.0",
    "better-auth": "^1.6.16",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb-keyval": "^6.2.5",
    "jszip": "^3.10.1",
    "kysely": "^0.29.2",
    "littlefs": "^0.1.0",
    "lucide-react": "^0.460.0",
    "monaco-editor": "0.55.1",
    "motion": "^12.40.0",
    "next": "^16.2.9",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^15.7.4",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "rp2040js": "1.3.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "raw-loader": "^4.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
